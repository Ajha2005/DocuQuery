# Database
DATABASE_URL=postgresql://docuquery_user:docuquery_pass@localhost:5433/docuquery_db

# Groq API
GROQ_API_KEY=your_groq_api_key_here

# Embeddings (local model name from HuggingFace)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Groq model to use for chat
GROQ_MODEL=openai/gpt-oss-20b

# App settings
APP_ENV=development
